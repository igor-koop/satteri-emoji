{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "satteri-emoji",
  "version": "0.1.0",
  "private": false,
  "description": "Satteri plugin to replace emoji shortcodes and emoticons in Markdown text.",
  "keywords": [
    "emoji",
    "emoticon",
    "markdown",
    "mdast",
    "mdx",
    "satteri",
    "shortcode"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/igor-koop/satteri-emoji.git"
  },
  "files": [
    "dist/index.d.ts",
    "dist/index.d.ts.map",
    "dist/index.js",
    "dist/index.js.map",
    "dist/registry.d.ts",
    "dist/registry.d.ts.map",
    "dist/registry.js",
    "dist/registry.js.map"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "data": "node data.ts",
    "build": "tsc --project tsconfig.build.json",
    "check": "oxfmt --check && oxlint && tsc --noEmit",
    "check:fmt": "oxfmt --check",
    "check:lint": "oxlint",
    "check:type": "tsc --noEmit",
    "fmt": "oxfmt",
    "lint": "oxlint",
    "test": "vitest run",
    "cov": "vitest run --coverage"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/regexgen": "^1.3.3",
    "@vitest/coverage-v8": "^4.1.7",
    "emojibase": "^17.0.0",
    "emojibase-data": "^17.0.0",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "regexgen": "^1.3.0",
    "satteri": "^0.9.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "peerDependencies": {
    "satteri": "^0.9.3"
  },
  "engines": {
    "node": ">=20"
  }
}
